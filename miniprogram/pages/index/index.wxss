.field + .field {
  margin-top: 22rpx;
}

.label {
  color: #334155;
  font-size: 24rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.picker {
  align-items: center;
  border: 1rpx solid #d8dee8;
  border-radius: 8rpx;
  color: #172033;
  display: flex;
  min-height: 76rpx;
  padding: 0 20rpx;
}

.title.small {
  font-size: 30rpx;
}

.compact {
  min-height: 64rpx;
  padding: 0 22rpx;
}

.product-row {
  align-items: flex-start;
  border-top: 1rpx solid #edf1f5;
  display: flex;
  gap: 16rpx;
  padding: 22rpx 0;
}

.product-main {
  flex: 1;
  min-width: 0;
}

.product-title {
  font-weight: 600;
  line-height: 1.45;
}

.product-meta {
  align-items: center;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.score {
  color: #b45309;
  font-size: 22rpx;
}

.message {
  border: 1rpx solid #d8dee8;
  border-radius: 8rpx;
  box-sizing: border-box;
  min-height: 260rpx;
  padding: 18rpx;
  width: 100%;
}

.actions {
  bottom: 0;
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
  padding-bottom: env(safe-area-inset-bottom);
  position: sticky;
}
